server {
    listen 8080;

    location / {
        root /usr/share/nginx/html;
        index index.html;
        try_files $uri $uri/ /index.html;
    }

    location /api/ {
        proxy_pass https://revenue-intelligence-364307352476.us-east1.run.app/api/;;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}